{
    "name": "hello-world",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "serve": "vue-cli-service serve",
        "_comment_build": "--no-module: emit one browserslist-transpiled bundle instead of Vue CLI 5's default modern+legacy pair. django-webpack-loader renders a single <script>, so the modern half would ship untranspiled code to old browsers.",
        "build": "vue-cli-service build --no-module",
        "lint": "vue-cli-service lint"
    },
    "dependencies": {
        "@fortawesome/fontawesome-svg-core": "^1.2.18",
        "@fortawesome/free-solid-svg-icons": "^5.8.2",
        "@fortawesome/vue-fontawesome": "^0.1.6",
        "axios": "^0.19.0",
        "bootstrap-vue": "^2.0.1",
        "codemirror": "^5.65.1",
        "vue": "^2.6.10",
        "vue-axios": "^2.1.4",
        "vue-filter-date-format": "^1.3.1",
        "vue-multipane": "^0.9.5",
        "vue-router": "^3.0.6",
        "vue-star-rating": "^1.6.1",
        "vue-table-dynamic": "^0.4.10",
        "vue-toastification": "^1.7.7",
        "vuex": "^3.1.3",
        "vuex-persistedstate": "^3.0.1"
    },
    "devDependencies": {
        "@babel/core": "^7.24.0",
        "@babel/eslint-parser": "^7.24.0",
        "@vue/cli-plugin-babel": "^5.0.8",
        "@vue/cli-plugin-eslint": "^5.0.8",
        "@vue/cli-service": "^5.0.8",
        "eslint": "^8.57.0",
        "eslint-plugin-vue": "^9.23.0",
        "sass": "^1.54.5",
        "sass-loader": "^13.3.0",
        "vue-template-compiler": "^2.6.10",
        "webpack-bundle-tracker": "^3.2.4"
    },
    "eslintConfig": {
        "root": true,
        "env": {
            "node": true
        },
        "extends": [
            "plugin:vue/essential",
            "eslint:recommended"
        ],
        "rules": {},
        "parserOptions": {
            "parser": "@babel/eslint-parser"
        },
        "globals": {
            "AiravataAPI": "readonly"
        }
    },
    "postcss": {
        "plugins": {
            "autoprefixer": {}
        }
    },
    "browserslist": [
        "> 1%",
        "last 2 versions",
        "not ie <= 8"
    ]
}
